@page "/myskins"
@using Microsoft.AspNetCore.Authorization
@using Poker.Models.DTOs
@using Poker.Services
@attribute [Authorize]
@rendermode InteractiveServer
@inject IHttpContextAccessor HttpContextAccessor
@inject UtilService UtilService
@inject NavigationManager Navigation

<PageTitle>My Skins</PageTitle>

@if (skins == null)
{
    <div class="loading">
        <h1>Loading skins...</h1>
    </div>
}
else
{
    <div class="skins-container">
        @foreach (var skin in skins.Skins)
        {
            <div class="skin-card">
                <img src="@($"images/cardReverses/{skin.Key}")" alt="skin" />

                @if (skin.Value)
                {
                    <img style="width: 50%" src="images/buttons/usingOff.png" alt="Using" />
                }
                else
                {
                    <img style="width: 50%" src="@buttonImages[skin.Key]" alt="Use"
                         @onpointerleave="() => OffButton(skin.Key)"
                         @onpointerenter="() => OverButton(skin.Key)"
                         @onpointerdown="() => HandleEquip(skin.Key)"
                         @onpointerup="() => OverButton(skin.Key)">
                }
            </div>
        }
    </div>
}

@code {
    private string currentUserName;
    OwnedSkinsDTO? skins;
    private Dictionary<string, string>? buttonImages;

    protected override async Task OnInitializedAsync()
    {
        currentUserName = HttpContextAccessor.HttpContext?.User?.Identity?.Name;

        if (string.IsNullOrEmpty(currentUserName))
        {
            Navigation.NavigateTo("/menu");
            return;
        }
        await SetSkins();
    }

    private async Task HandleEquip(string fileName)
    {
        ClickButton(fileName);

        await UtilService.ChangeEquippedSkinAsync(currentUserName, fileName);

		await SetSkins();
    }

    private async Task SetSkins()
    {
        skins = await UtilService.GetOwnedSkinsAsync(currentUserName);
		buttonImages = new Dictionary<string, string>();
        foreach (var skin in skins.Skins)
        {
            if (!skin.Value)
            {
				buttonImages.Add(skin.Key, "images/buttons/useOff.png");
            }
		}
    }


    private void OffButton(string fileName)
    {
        buttonImages[fileName] = "images/buttons/useOff.png";
    }

    private void OverButton(string fileName)
    {
        buttonImages[fileName] = "images/buttons/useOn.png";
    }

    private void ClickButton(string fileName)
    {
        buttonImages[fileName] = "images/buttons/useClick.png";
    }
}